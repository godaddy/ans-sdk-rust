{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "include-component-in-tag": true,
  "changelog-sections": [
        { "type": "feat", "section": "Features" },
        { "type": "fix", "section": "Bug Fixes" },
        { "type": "perf", "section": "Performance Improvements" },
        { "type": "revert", "section": "Reverts" },
        { "type": "docs", "section": "Documentation" },
        { "type": "chore", "section": "Miscellaneous" },
        { "type": "refactor", "section": "Code Refactoring" },
        { "type": "style", "section": "Styles" },
        { "type": "test", "section": "Tests" },
        { "type": "build", "section": "Build System" },
        { "type": "ci", "section": "Continuous Integration", "hidden": true }
  ],
  "packages": {
    "crates/ans-types": {
      "release-type": "rust",
      "component": "ans-types",
      "extra-files": [
        {
          "type": "toml",
          "path": "../../Cargo.toml",
          "jsonpath": "$.workspace.package.version"
        },
        {
          "type": "toml",
          "path": "../../Cargo.toml",
          "jsonpath": "$.workspace.dependencies.ans-types.version"
        }
      ]
    },
    "crates/ans-verify": {
      "release-type": "rust",
      "component": "ans-verify",
      "extra-files": [
        {
          "type": "toml",
          "path": "../../Cargo.toml",
          "jsonpath": "$.workspace.dependencies.ans-verify.version"
        }
      ]
    },
    "crates/ans-client": {
      "release-type": "rust",
      "component": "ans-client",
      "extra-files": [
        {
          "type": "toml",
          "path": "../../Cargo.toml",
          "jsonpath": "$.workspace.dependencies.ans-client.version"
        }
      ]
    }
  },
  "plugins": [
    {
      "type": "cargo-workspace"
    },
    {
      "type": "linked-versions",
      "groupName": "ans-sdk",
      "components": ["ans-types", "ans-verify", "ans-client"]
    }
  ]
}
